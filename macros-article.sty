\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{macros-article}[2026/04/12 v1.0]
% --------------------------------------------
% -------------  PACKAGE IMPORTS -------------
% --------------------------------------------
\RequirePackage[a4paper, left=1cm, right=1cm, top=1cm, bottom=2.5cm]{geometry}
\RequirePackage[most]{tcolorbox}
\RequirePackage{xcolor}
\RequirePackage{multicol}
\usepackage{tikz}
\usetikzlibrary{positioning, calc, arrows.meta}

% --------------------------------------------
% ------------------ COLORS ------------------
% --------------------------------------------
\definecolor{headerDark}{HTML}{333333}
\definecolor{mintBox}{HTML}{A7E8D8}
\definecolor{codeBlack}{HTML}{222222}
\definecolor{mintShadow}{HTML}{7ABAA9}
\definecolor{gitRed}{HTML}{FF6B6B}


% --------------------------------------------
% -------- CUSTOM COMMANDS & MACROS   --------
% --------------------------------------------



% ------- Custom boxes -------
% ----------------------------
\newtcolorbox{gitBaseCard}[1]{
    enhanced,
    sharp corners,
    colback=white,
    colframe=headerDark,
    fonttitle=\sffamily\bfseries\large,
    title={#1},
    attach boxed title to top left={yshift=-2.5mm, xshift=2mm},
    boxed title style={sharp corners, colback=headerDark, colframe=headerDark},
    left=0mm, right=2mm, top=4mm, bottom=2mm,
    boxrule=1.5pt
}

\newtcolorbox{gitsection}[1]{
    enhanced,
    sharp corners,
    colback=mintBox,
    colframe=mintBox,
    fontupper=\sffamily\bfseries,
    left=4mm, right=4mm, top=2mm, bottom=2mm,
    boxrule=0pt,
    title={#1},
    coltitle=black,
    attach title to upper,
    after title={\par\smallskip},
    grow to left by=4mm,
    % grow to right by=0mm
    % the ribbon fold corner
    finish={
        \fill[mintShadow] ([xshift=2.47mm]frame.north west) -- (frame.north west) -- ([xshift=2.47mm, yshift=1.2mm]frame.north west) -- cycle;
    }
}

% Main Card Container
\newtcolorbox{gitFlowCard}[1]{
    enhanced,
    sharp corners,
    colback=white,
    colframe=gitRed,
    fonttitle=\sffamily\bfseries,
    title={#1},
    attach boxed title to top left={yshift=-2mm, xshift=-0.5mm},
    boxed title style={sharp corners, colback=gitRed, colframe=gitRed},
    left=5mm, right=2mm, top=5mm, bottom=2mm,
    boxrule=1.5pt
}



% ---- Custom commands   ----
% ---------------------------
\newcommand{\gitinline}[1]{%
  \colorbox{black}{\textcolor{white}{\lstinline!#1!}}%
}

\newcommand{\gitcommand}[2]{%
    \begin{tcolorbox}[
        sharp corners, 
        colback=codeBlack, 
        colframe=codeBlack, 
        boxrule=0pt,
        top=1.5mm, bottom=1.5mm, left=0.5mm,
        fontupper=\ttfamily\color{white}
    ]
    #1
    \end{tcolorbox}
    #2
}
% creating the small flag explanations for git
\newcommand{\gitflag}[4]{%
    \begin{minipage}{#1\textwidth}
                    \gitcommand{#2}
                \end{minipage}
                \hspace{1mm}
                \begin{minipage}{#3\textwidth}
                    \textsf{\small #4}
                \end{minipage}%
}

% Code Label Style
\newcommand{\gitlabel}[1]{%
    \begin{tikzpicture}[baseline=(char.base)]
        \node[
            fill=codeBlack, 
            text=white, 
            rounded corners=2pt, 
            inner sep=4pt, 
            font=\ttfamily\small
        ] (char) {#1};
    \end{tikzpicture}%
}

